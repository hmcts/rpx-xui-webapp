#!groovy

properties([
    [
        $class       : 'GithubProjectProperty',
        displayName  : 'Expert UI Webapp',
        projectUrlStr: 'https://github.com/hmcts/rpx-xui-webapp/'
    ],
    pipelineTriggers([
        [$class: 'GitHubPushTrigger']
    ]),
    parameters([
        choice(name: 'ENVIRONMENT', choices: 'saat\nsandbox\nsprod', description: 'Environment where code should be build and deployed'),
        booleanParam(
            name: 'RUN_PLAYWRIGHT_ACCESSIBILITY',
            defaultValue: false,
            description: 'Manual-only: run the non-blocking unified Playwright accessibility pack.'
        )
    ])
])

@Library("Infrastructure2.4.0")

def type      = "nodejs"
def product   = "xui"
def component = "webapp"
def vault     = "rpx"
def channel   = '#xui-pipeline'

List<LinkedHashMap<String, Object>> secrets = [
  secret('mc-s2s-client-secret',                 'S2S_SECRET'),
  secret('mc-idam-client-secret',              'IDAM_SECRET'),
  secret('appinsights-instrumentationkey-mc', 'APPINSIGHTS_INSTRUMENTATIONKEY'),
  secret('appinsights-connection-string-mc', 'APPINSIGHTS_CONNECTION_STRING'),
  secret('launch-darkly-client-id', 'LAUNCH_DARKLY_CLIENT_ID'),
  secret('system-user-name', 'SYSTEM_USER_NAME'),
  secret('system-user-password', 'SYSTEM_USER_PASSWORD'),
  secret('mc-session-secret', 'SESSION_SECRET'),
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

def ensureHtmlReportForPublishing = { String reportDir, String reportFile, String suiteName ->
    withEnv([
        "PW_ODHIN_ENSURE_REPORT_DIR=${reportDir}",
        "PW_ODHIN_ENSURE_REPORT_FILE=${reportFile}",
        "PW_ODHIN_ENSURE_SUITE_NAME=${suiteName}"
    ]) {
        sh '''
            node scripts/ensure-odhin-report.js \
              --report-dir "$PW_ODHIN_ENSURE_REPORT_DIR" \
              --report-file "$PW_ODHIN_ENSURE_REPORT_FILE" \
              --suite-name "$PW_ODHIN_ENSURE_SUITE_NAME"
        '''
    }
}

def publishPlaywrightReport = { String reportDir, String reportFile, String reportName, String artifacts ->
    ensureHtmlReportForPublishing(reportDir, reportFile, reportName)
    publishHTML([
        allowMissing         : true,
        alwaysLinkToLastBuild: true,
        keepAll              : true,
        reportDir            : reportDir,
        reportFiles          : reportFile,
        reportName           : reportName
    ])
    junit(allowEmptyResults: false, testResults: artifacts.replace('**', '**/*junit.xml'))
    archiveArtifacts allowEmptyArchive: true, artifacts: artifacts
}

def runManualPlaywrightAccessibility = { String environmentName ->
    if (!params.RUN_PLAYWRIGHT_ACCESSIBILITY) {
        echo '[playwright-accessibility] Manual accessibility pack disabled for this parameterized build.'
        return
    }

    stage("${environmentName} Manual Playwright Accessibility") {
        stage('Playwright Accessibility Tests') {
            try {
                withEnv([
                    "ORG_USER_ASSIGNMENT_MODE=external",
                    "ORG_USER_ASSIGNMENT_MODE_ORDER=external,internal",
                    "PW_ACCESSIBILITY_WORKERS=6",
                    "FUNCTIONAL_TESTS_WORKERS=6",
                    "PW_SESSION_CAPTURE_FAILURE_TTL_MS=0",
                    "PLAYWRIGHT_JUNIT_OUTPUT=functional-output/tests/playwright-accessibility/playwright-accessibility-junit.xml"
                ]) {
                    sh 'yarn test:accessibility:playwright'
                }
            } catch (Exception e) {
                echo "[playwright-accessibility] Accessibility failed but is non-blocking: ${e.getClass().getName()}: ${e.getMessage()}"
            } finally {
                try {
                    publishPlaywrightReport(
                        'functional-output/tests/playwright-accessibility/odhin-report',
                        'xui-playwright-accessibility.html',
                        "${environmentName} Playwright Accessibility",
                        'functional-output/tests/playwright-accessibility/**'
                    )
                } catch (Exception publishException) {
                    echo "[playwright-accessibility] Report/evidence publish failed but is non-blocking: ${publishException.getClass().getName()}: ${publishException.getMessage()}"
                }
            }
        }
    }
}

withParameterizedPipeline(type, product, component, params.ENVIRONMENT, 'sandbox') {
  enableSlackNotifications(channel)
  enableDockerBuild()
  loadVaultSecrets(secrets)
  setVaultName(vault)
  installCharts()


    after('checkout') {sh 'yarn cache clean'}
    after('checkout') {
        if (params.RUN_PLAYWRIGHT_ACCESSIBILITY) {
            sh 'yarn test:setup:playwright-install-chromium'
            sh 'yarn test:setup:playwright-verify-chromium'
        }
    }

    after('build') {
        sh 'npm run build'

        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "test/reports/lint/node/",
            reportFiles          : 'index.html',
            reportName           : 'node lint Report'
