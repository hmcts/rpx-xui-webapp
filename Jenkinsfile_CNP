def publishCiLoadProfile = { String reportName ->
    if (ciLoadProfilePublished) {
        return
    }
    ciLoadProfilePublished = true
    stopPlaywrightLoadProfile(ciLoadProfileDir)
    publishPlaywrightLoadProfile(ciLoadProfileDir, reportName)
}

def playwrightLoadProfileEventsFile = { String testType ->
