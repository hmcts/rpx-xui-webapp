def assertHtmlReportExists = { String reportDir, String reportFile ->
    steps.sh "test -f '${reportDir}/${reportFile}'"
}

def ensureHtmlReportForPublishing = { String reportDir, String reportFile, String suiteName ->
    withEnv([
        "PW_ODHIN_ENSURE_REPORT_DIR=${reportDir}",
        "PW_ODHIN_ENSURE_REPORT_FILE=${reportFile}",
        "PW_ODHIN_ENSURE_SUITE_NAME=${suiteName}"
    ]) {
        steps.sh '''
            node scripts/ensure-odhin-report.js \
              --report-dir "$PW_ODHIN_ENSURE_REPORT_DIR" \
              --report-file "$PW_ODHIN_ENSURE_REPORT_FILE" \
              --suite-name "$PW_ODHIN_ENSURE_SUITE_NAME"
        '''
    }
}

def publishPlaywrightLoadProfile = { String reportDir, String reportName ->
    def safeReportName = reportName.replaceAll(/[^A-Za-z0-9._-]/, '-')
    def slimReportDir = "functional-output/tests/playwright-published-reports/load-profile/${safeReportName}"
    steps.sh """
        set +e
        node scripts/ensure-load-profile-report.js \\
          --report-dir '${reportDir}' \\
          --report-file '${playwrightLoadProfileReportFile}' \\
          --report-name '${reportName}'
    """
    steps.sh """
        set +e
        mkdir -p '${slimReportDir}'
        if [ -f '${reportDir}/${playwrightLoadProfileReportFile}' ]; then
          cp '${reportDir}/${playwrightLoadProfileReportFile}' '${slimReportDir}/${playwrightLoadProfileReportFile}'
        fi
    """
    steps.archiveArtifacts(
        allowEmptyArchive: true,
        artifacts: "${slimReportDir}/${playwrightLoadProfileReportFile}"
    )
    publishHTML([
        allowMissing         : true,
        alwaysLinkToLastBuild: true,
        keepAll              : true,
        reportDir            : "${slimReportDir}/",
        reportFiles          : playwrightLoadProfileReportFile,
        reportName           : reportName
    ])
}

def startPlaywrightLoadProfile = { String reportDir, String label, String eventsFile ->
    steps.sh """
        set +e
        mkdir -p '${reportDir}'
        rm -f '${reportDir}/stop' '${reportDir}/monitor.pid'
        JENKINS_NODE_COOKIE=dontKillMe nohup node scripts/playwright-load-monitor.js \\
          --output-folder '${reportDir}' \\
          --label '${label}' \\
          --events-file '${eventsFile}' \\
          --stop-file '${reportDir}/stop' \\
          > '${reportDir}/monitor.log' 2>&1 &
        echo \$! > '${reportDir}/monitor.pid'
    """
}

def stopPlaywrightLoadProfile = { String reportDir ->
    steps.sh """
        set +e
        if [ -f '${reportDir}/monitor.pid' ]; then
          pid=\$(cat '${reportDir}/monitor.pid')
          touch '${reportDir}/stop'
          for i in \$(seq 1 30); do
            kill -0 "\${pid}" 2>/dev/null || break
            sleep 1
          done
          if kill -0 "\${pid}" 2>/dev/null; then
            kill -TERM "\${pid}" 2>/dev/null || true
            sleep 2
          fi
        fi
        if [ -f '${reportDir}/monitor.log' ]; then
          cat '${reportDir}/monitor.log'
        fi
    """
}

