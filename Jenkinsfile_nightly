def archivePlaywrightDiagnostics = {
    steps.sh '''
        set +e
        out_dir="functional-output/tests/playwright-diagnostics/failure-data"
        mkdir -p "${out_dir}"
        if [ -d test-results ]; then
          find test-results -type f -name 'failure-data.json' | while read -r file; do
            rel="${file#test-results/}"
            safe_name=$(echo "${rel}" | tr '/ ' '__')
            cp "${file}" "${out_dir}/${safe_name}"
          done
        fi
    '''
    steps.archiveArtifacts(
        allowEmptyArchive: true,
        artifacts: 'functional-output/tests/playwright-diagnostics/failure-data/**/*',
        excludes: 'test-results/.playwright-artifacts-*/**,**/.playwright-artifacts-*/**'
    )
}

def playwrightIntegrationReportFile = 'xui-playwright-integration.html'
def playwrightLoadProfileReportFile = 'load-profile.html'

def assertHtmlReportExists = { String reportDir, String reportFile ->
    steps.sh "test -f '${reportDir}/${reportFile}'"
}

def ensureHtmlReportForPublishing = { String reportDir, String reportFile, String suiteName ->
    withEnv([
        "PW_ODHIN_ENSURE_REPORT_DIR=${reportDir}",
        "PW_ODHIN_ENSURE_REPORT_FILE=${reportFile}",
        "PW_ODHIN_ENSURE_SUITE_NAME=${suiteName}"
    ]) {
        steps.sh '''
            node scripts/ensure-odhin-report.js \
              --report-dir "$PW_ODHIN_ENSURE_REPORT_DIR" \
              --report-file "$PW_ODHIN_ENSURE_REPORT_FILE" \
              --suite-name "$PW_ODHIN_ENSURE_SUITE_NAME"
        '''
    }
}

def publishPlaywrightLoadProfile = { String reportDir, String reportName ->
    def safeReportName = reportName.replaceAll(/[^A-Za-z0-9._-]/, '-')
    def slimReportDir = "functional-output/tests/playwright-published-reports/load-profile/${safeReportName}"
    steps.sh """
      set +e
      mkdir -p '${slimReportDir}'
      if [ -f '${reportDir}/${playwrightLoadProfileReportFile}' ]; then
        cp '${reportDir}/${playwrightLoadProfileReportFile}' '${slimReportDir}/${playwrightLoadProfileReportFile}'
      fi
    """
    publishHTML([
      allowMissing         : true,
      alwaysLinkToLastBuild: true,
      keepAll              : true,
      reportDir            : "${slimReportDir}/",
      reportFiles          : playwrightLoadProfileReportFile,
      reportName           : reportName
    ])
}

def playwrightLoadProfileEventsFile = { ->
    'functional-output/tests/playwright-integration/load-profile/nightly-stage-events.jsonl'
}

def recordPlaywrightLoadEvent = { String label, String eventType ->
    try {
        steps.sh "node scripts/playwright-load-event.js '${playwrightLoadProfileEventsFile()}' '${label}' '${eventType}'"
    } catch (Exception e) {
        echo "[load-profile] failed to record ${label} ${eventType}: ${e.getMessage()}"
    }
}

def resolveIntegrationProfileRuns = { String configuredRuns, String workersOverride, String shardOverride ->
    def requestedWorkers = workersOverride?.trim()
    if (requestedWorkers) {
        def requestedShard = shardOverride?.trim()
        return ["workers=${requestedWorkers}${requestedShard ? " shard=${requestedShard}" : ''}"]
    }
    def configured = configuredRuns?.trim()
    if (!configured) {
        configured = 'workers=4'
    }
    return configured
        .split(/[\r\n;]+/)
        .collect { it.trim() }
        .findAll { it }
}

def integrationProfileRunConfig = { String spec ->
    def workers = '4'
    def shard = ''
    spec.split(/\s+/).each { token ->
        if (token.startsWith('workers=')) {
            workers = token.replaceFirst('workers=', '')
        }
        if (token.startsWith('shard=')) {
            shard = token.replaceFirst('shard=', '')
        }
    }
    def safeName = "workers-${workers}${shard ? "-shard-${shard}" : ''}".replaceAll(/[^A-Za-z0-9._-]/, '-')
    return [
        workers: workers,
        shard: shard,
        shardArg: shard ? " --shard=${shard}" : '',
        label: "nightly-${safeName}",
        reportDir: "functional-output/tests/playwright-integration/odhin-report/nightly-${safeName}",
        loadProfileDir: "functional-output/tests/playwright-integration/load-profile/nightly-${safeName}",
        displayName: "${workers} workers${shard ? ", shard ${shard}" : ''}"
    ]
}

def runPlaywrightIntegrationProfileMatrix = {
    def failures = []
    resolveIntegrationProfileRuns(params.INTEGRATION_PW_PROFILE_RUNS ?: '', params.INTEGRATION_PW_WORKERS ?: '', params.INTEGRATION_PW_SHARD ?: '').each { spec ->
        def runConfig = integrationProfileRunConfig(spec)
        try {
            withEnv([
              "PLAYWRIGHT_REPORT_FOLDER=${runConfig.reportDir}",
              "PW_LOAD_PROFILE_OUTPUT=${runConfig.loadProfileDir}",
              "PW_LOAD_PROFILE_LABEL=${runConfig.label}",
              "PW_LOAD_PROFILE_INJECT_ODHIN=false",
              "PW_LOAD_PROFILE_EVENTS_FILE=${playwrightLoadProfileEventsFile()}",
              "PW_LOAD_PROFILE_CHILD_IDLE_TIMEOUT_MS=30000",
              "PW_LOAD_PROFILE_CHILD_TERMINATE_GRACE_MS=10000",
              'ORG_USER_ASSIGNMENT_MODE=external',
              'ORG_USER_ASSIGNMENT_MODE_ORDER=external,internal',
              "FUNCTIONAL_TESTS_WORKERS=${runConfig.workers}",
              'PLAYWRIGHT_SKIP_INSTALL=true'
            ]) {
              yarnBuilder.yarn("test:playwright:integration:profile -- --workers=${runConfig.workers}${runConfig.shardArg}")
            }
            echo "[playwright-integration] Completed test command for ${runConfig.displayName}; checking Odhín report at ${runConfig.reportDir}/${playwrightIntegrationReportFile}"
            assertHtmlReportExists(runConfig.reportDir, playwrightIntegrationReportFile)
            echo "[playwright-integration] Odhín report exists for ${runConfig.displayName}"
        } catch (Exception e) {
            if (e instanceof org.jenkinsci.plugins.workflow.steps.FlowInterruptedException) {
                throw e
            }
            if (e instanceof hudson.AbortException && ((e.getMessage() ?: '') =~ /(exit code|status)\s+(129|137|143)/).find()) {
                throw e
            }
            failures << "${runConfig.displayName}: ${e.getMessage()}"
        } finally {
            echo "[playwright-integration] Publishing Odhín HTML report for ${runConfig.displayName}"
            ensureHtmlReportForPublishing(
              runConfig.reportDir,
              playwrightIntegrationReportFile,
              "Playwright Integration Tests"
            )
            publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : "${runConfig.reportDir}/",
              reportFiles          : playwrightIntegrationReportFile,
              reportName           : "Playwright Integration Tests"
            ])
            publishPlaywrightLoadProfile(
              runConfig.loadProfileDir,
              "Playwright Integration System Load"
            )
            echo "[playwright-integration] Published Odhín HTML report for ${runConfig.displayName}"
        }
    }
    if (failures) {
        error("Playwright integration profile matrix failed:\n${failures.join('\n')}")
    }
}

