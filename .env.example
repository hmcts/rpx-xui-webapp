# Repo-wide local env template for rpx-xui-webapp.
# Copy to .env and populate tagged secrets from Azure Key Vault:
#   yarn env:populate:aat
#   yarn env:populate:demo
#
# If adding a new value, ensure Key Vault is updated and tagged with:
#   e2e=ENV_VAR_NAME
# Compatibility fills are derived by scripts/populate-env-from-keyvault.sh for:
#   CLIENT_ID, CREATE_USER_CLIENT_ID, CREATE_USER_CLIENT_SECRET,
#   IDAM_API_URL, MANAGE_CASE_REDIRECT_URI, SOLICITOR_CASE_TYPE,
#   SOLICITOR_JURISDICTION
#
# Notes:
# - Keep placeholders only in this file. Do not commit live secret values.
# - Blank values are expected to be filled by the Key Vault population flow or local overrides.

# General
TEST_ENV=aat
TEST_URL=
EXUI_BASE_URL=
MANAGE_CASES_BASE_URL=
BACKEND_BASE_URL=
CITIZEN_FRONTEND_BASE_URL=
JURISDICTION=PRIVATELAW
CASE_TYPE=PRLAPPS

# Node/API local defaults
NODE_CONFIG_DIR=../config
NODE_CONFIG_ENV=development
ALLOW_CONFIG_MUTATIONS=1
FEATURE_APP_INSIGHTS_ENABLED=false

# IDAM
IDAM_SECRET=
IDAM_WEB_URL=
IDAM_TESTING_SUPPORT_USERS_URL=
IDAM_TESTING_SUPPORT_URL=
IDAM_CITIZEN_USER_PASSWORD=
IDAM_API_URL=
IDAM_OAUTH2_SCOPE=openid profile roles
IDAM_CLIENT_ID=
CLIENT_ID=
IDAM_RETURN_URL=
SERVICES_IDAM_WEB_URL=
SERVICES_IDAM_API_URL=
SERVICES_IDAM_CLIENT_ID=xuiwebapp

# CourtNav
COURTNAV_SECRET=
COURTNAV_USERNAME=
COURTNAV_PASSWORD=
COURTNAV_SUBSCRIPTION_KEY_CREATE_CASE=
COURTNAV_CASE_URL=
COURTNAV_DOC_URL=
COURTNAV_SUBSCRIPTION_KEY_ADD_DOC=

# S2S
S2S_URL=
S2S_SECRET=
MICROSERVICE=xui_webapp
S2S_MICROSERVICE_NAME=xui_webapp
S2S_TOKEN=

# CCD
CCD_DATA_STORE_CLIENT_USERNAME=
CCD_DATA_STORE_CLIENT_PASSWORD=
CCD_DATA_STORE_CLIENT_ID=
CCD_DATA_STORE_SECRET=
CCD_DATA_STORE_URL=

# Manage Case / downstream APIs
MANAGE_CASE_REDIRECT_URI=
PRL_COS_API_URL=
MANAGE_ORG_API_PATH=
RD_PROFESSIONAL_API_PATH=
SERVICES_PRD_API=

# Dynamic-user bootstrap
CREATE_USER_SCOPE=openid profile roles create-user manage-user search-user
CREATE_USER_CLIENT_ID=
CREATE_USER_CLIENT_SECRET=
CREATE_USER_BEARER_TOKEN=

ORG_USER_ASSIGNMENT_BEARER_TOKEN=
ORG_USER_ASSIGNMENT_USERNAME=
ORG_USER_ASSIGNMENT_PASSWORD=
IDAM_SOLICITOR_USER_PASSWORD=
IDAM_CASEWORKER_DIVORCE_PASSWORD=
ORG_USER_ASSIGNMENT_CLIENT_ID=
ORG_USER_ASSIGNMENT_CLIENT_SECRET=
ORG_USER_ASSIGNMENT_OAUTH2_SCOPE=openid profile roles
ORG_USER_ASSIGNMENT_EXPECTED_EMAIL=
ORG_USER_ASSIGNMENT_REDIRECT_URI=
ORG_USER_ASSIGNMENT_UI_USER=
ORG_USER_ASSIGNMENT_USER_ROLES=
ORG_USER_ASSIGNMENT_MODE=auto
ORG_USER_ASSIGNMENT_MODE_ORDER=internal,external
ORG_USER_ASSIGNMENT_REQUEST_TIMEOUT_MS=20000
ORG_ASSIGNMENT_ROLE_FILTER=true
TEST_SOLICITOR_ORGANISATION_ID=

# External professional-user assignment controls
PROFESSIONAL_USER_ASSIGNMENT_MODE=external
PROFESSIONAL_USER_ASSIGNMENT_FALLBACK_ORDER=external,internal
PROFESSIONAL_USER_EXTERNAL_ASSIGNMENT_MAX_ATTEMPTS=3
PROFESSIONAL_USER_EXTERNAL_ASSIGNMENT_RETRY_DELAY_MS=1000
PROFESSIONAL_USER_EMAIL_DOMAIN=test.local
PROFESSIONAL_USER_OUTPUT_CREATED_DATA=false
PROFESSIONAL_USER_ASSIGNMENT_USE_MANAGE_ORG_PRIMARY=true
PROFESSIONAL_USER_ENABLE_MANAGE_ORG_FALLBACK=true

# Dynamic solicitor template and profile controls
SOLICITOR_CASE_TYPE=PRLAPPS
SOLICITOR_JURISDICTION=PRIVATELAW
SOLICITOR_TEST_TYPE=provisioning
SOLICITOR_ROLE_PROFILE=minimal
PW_EMPLOYMENT_ASSIGNMENT_PREFLIGHT=true
DYNAMIC_SOLICITOR_TEMPLATE_ROLES=
DYNAMIC_PROD_LIKE_TEMPLATE_ROLES=

# Case setup strategy for tests where case creation is not under UI test
PW_E2E_CASE_SETUP_MODE=api-required
PW_E2E_CASE_SETUP_API_ENDPOINT=
PW_E2E_CASE_SETUP_TIMEOUT_MS=120000
PW_E2E_CASE_SETUP_ALLOW_UI_FALLBACK=false

# Guardrails for static/dynamic account usage in tests
BLOCKED_STATIC_USERNAMES=
ALLOW_CREDENTIAL_OUTPUT_IN_CI=false
ALLOW_ORG_ASSIGNMENT_IDAM_OAUTH_IN_WORKER=true

# Static aliases used by migrated E2E flows
SOLICITOR_USERNAME=
SOLICITOR_PASSWORD=
