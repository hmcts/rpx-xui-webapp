// In `parallel(failFast: true, ...)`, non-failing branches are stopped by Jenkins via a
// FlowInterruptedException. We only want those *interrupted* branches to show as ABORTED.
// The genuinely failing branch should remain FAILED.
def isFailFastInterruption = { org.jenkinsci.plugins.workflow.steps.FlowInterruptedException e ->
    try {
        return (e.getCauses() ?: []).any { c ->
            // FailFastCause exists under different packages across Jenkins versions.
            def name = c?.getClass()?.getName()
            return name?.endsWith('FailFastCause')
        }
    } catch (ignored) {
        return false
    }
}
// When failFast interrupts other branches, Jenkins may surface either:
// - FlowInterruptedException with a FailFastCause, or
// - AbortException from a terminated `sh` (e.g., exit 143).
// Normalize those to ABORTED so truly failing branches stay FAILED.
def handleFailFastAbort = { Exception e ->
    def abortedByFailFast = false
    def failFastExitCodes = ['129', '137', '143']
    if (e instanceof org.jenkinsci.plugins.workflow.steps.FlowInterruptedException) {
        try {
            def fie = (org.jenkinsci.plugins.workflow.steps.FlowInterruptedException) e
            def causes = (fie.getCauses() ?: []).collect { c -> c?.getClass()?.getName() }.findAll { it }
            abortedByFailFast = causes.any { it?.endsWith('FailFastCause') }
            echo "[failFast] FlowInterruptedException: causes=${causes}"
        } catch (ignored) {
            echo "[failFast] FlowInterruptedException: causes=<unavailable>"
        }
    } else if (e instanceof hudson.AbortException) {
        def msg = e.getMessage() ?: ''
        def matcher = (msg =~ /(exit code|status)\s+(\d+)/)
        def exitCode = matcher.find() ? matcher.group(2) : null
        abortedByFailFast = (currentBuild?.result == 'ABORTED') || (exitCode in failFastExitCodes)
        echo "[failFast] AbortException: buildResult=${currentBuild?.result}, exitCode=${exitCode}"
    } else {
        echo "[failFast] Non-abort exception: ${e.getClass().getName()}: ${e.getMessage()}"
    }
    if (abortedByFailFast) {
        echo "[failFast] Marking stage as ABORTED due to failFast interruption"
        catchError(buildResult: 'ABORTED', stageResult: 'ABORTED') { throw e }
        return true
    }
    echo "[failFast] Not a failFast interruption; rethrowing"
    return false
}

def archivePlaywrightDiagnostics = {
    steps.sh '''
        set +e
        out_dir="functional-output/tests/playwright-diagnostics/failure-data"
        mkdir -p "${out_dir}"
        if [ -d test-results ]; then
          find test-results -type f -name 'failure-data.json' | while read -r file; do
            rel="${file#test-results/}"
            safe_name=$(echo "${rel}" | tr '/ ' '__')
            cp "${file}" "${out_dir}/${safe_name}"
          done
        fi
    '''
    steps.archiveArtifacts(
        allowEmptyArchive: true,
        artifacts: 'functional-output/tests/**/odhin-report/**/*,test-results/**/*,functional-output/tests/playwright-diagnostics/failure-data/**/*,**/failure-data.json',
        excludes: 'test-results/.playwright-artifacts-*/**,**/.playwright-artifacts-*/**'
    )
}

def resolveAgentCpuCount = {
    def raw = steps.sh(
        script: '''
            set +e
            if command -v getconf >/dev/null 2>&1; then
              getconf _NPROCESSORS_ONLN
              exit 0
            fi
            if command -v nproc >/dev/null 2>&1; then
              nproc
              exit 0
            fi
            if command -v sysctl >/dev/null 2>&1; then
              sysctl -n hw.logicalcpu
              exit 0
            fi
            echo 1
        ''',
        returnStdout: true
    ).trim()
    try {
        return Math.max(1, Integer.parseInt(raw))
    } catch (ignored) {
        return 1
    }
}

def resolveParallelTestWorkerPlan = {
    def cpuCount = resolveAgentCpuCount()
    def branchOrder = ['playwrightE2E', 'playwrightIntegration', 'codecept', 'api']
    def branchCount = branchOrder.size()
    def maxWorkersPerBranch = 8
    def baseline = Math.max(1, cpuCount.intdiv(branchCount))
    def remainder = Math.max(0, cpuCount - (baseline * branchCount))
    def allocations = [:]

    branchOrder.eachWithIndex { branchName, index ->
        def allocation = baseline + (index < remainder ? 1 : 0)
        allocations[branchName] = Math.min(maxWorkersPerBranch, Math.max(1, allocation))
    }

    echo "[parallel-workers] detected_cpu=${cpuCount} plan=${allocations.collect { name, count -> "${name}=${count}" }.join(', ')}"
    return [cpuCount: cpuCount, allocations: allocations]
}

